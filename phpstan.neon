includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/mrpunyapal/peststan/extension.neon

parameters:

    paths:
        - app/
        - database/
        - routes/
        - tests/

    # The level 9 is the highest level
    level: 5

    ignoreErrors:
        -
            message: '#Undefined variable: \$this#'
            path: tests/Pest.php
